---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import { graphics } from "../data/graphics";
import replayCsv from "../data/GR-replays.csv?raw";

const {
  title,
  description,
  sectionTitle,
  seasonNumber,
  guides = []
} = Astro.props;

const archiveGuide = {
  title: "Guild Raid Archive",
  href: "/guild-raid/archive",
  description: "Browse previous Guild Raid seasons, boss lineups, maps, and infographic archives.",
  thumbnail: "/images/web/guild-raid-s101-mythic.webp"
};

const relatedGuides = [
  archiveGuide,
  ...graphics.filter(
    (g) =>
      g.href !== Astro.url.pathname &&
      g.href !== "/guild-raid/archive"
  )
];

const sortedRelatedGuides = relatedGuides.sort((a, b) => {
  const priority = {
    "/guild-raid/boss-meta": 1,
    "/guild-raid/archive": 2
  };

  return (priority[a.href] || 99) - (priority[b.href] || 99);
});

function parseCsv(csv) {
  const rows = [];
  let row = [];
  let field = "";
  let inQuotes = false;

  for (let i = 0; i < csv.length; i++) {
    const char = csv[i];
    const next = csv[i + 1];

    if (char === '"' && inQuotes && next === '"') {
      field += '"';
      i++;
    } else if (char === '"') {
      inQuotes = !inQuotes;
    } else if (char === "," && !inQuotes) {
      row.push(field);
      field = "";
    } else if ((char === "\n" || char === "\r") && !inQuotes) {
      if (field || row.length) {
        row.push(field);
        rows.push(row);
        row = [];
        field = "";
      }
      if (char === "\r" && next === "\n") i++;
    } else {
      field += char;
    }
  }

  if (field || row.length) rows.push([...row, field]);

  const headers = rows.shift();

  return rows.map((values) =>
    Object.fromEntries(headers.map((header, index) => [header, values[index] || ""]))
  );
}

function getGuideReplayRows(guide, seasonReplays) {
  if (guide.title.includes("Mythic")) {
    return seasonReplays.filter((row) => row.TIER.startsWith("M"));
  }

  if (guide.title.includes("Legendary")) {
    return seasonReplays.filter((row) => row.TIER.startsWith("L"));
  }

  if (guide.title.includes("Epic")) {
    return seasonReplays.filter((row) => row.TIER.startsWith("E"));
  }

  return [];
}

const tierOrder = {
  E1: 1, E2: 2, E3: 3, E4: 4, E5: 5,
  L1: 6, L2: 7, L3: 8, L4: 9, L5: 10,
  M1: 11, M2: 12
};

const seasonReplays = parseCsv(replayCsv)
  .filter((row) => String(row.SEASON) === String(seasonNumber))
  .sort((a, b) => {
    const tierDiff = (tierOrder[b.TIER] || 0) - (tierOrder[a.TIER] || 0);
    if (tierDiff !== 0) return tierDiff;

    return a.BOSS.localeCompare(b.BOSS);
  });

---

<Header />

<main>
  <section class="boss-meta-cta">
    <h2>Need Team Recommendations?</h2>
    <p>
      Looking for the strongest teams for each Guild Raid boss?<br>
      Check out the Boss Meta Guide, built from extensive YouTube replay analysis.
    </p>

    <a href="/guild-raid/boss-meta/" class="boss-meta-button">
      View Boss Meta Guide →
    </a>
  </section>

  <section class="infographic-section">
    <h2>{sectionTitle}</h2>

    <div class="guide-grid">
      {guides.map((guide) => (
        <article class="guide-card">
          <h3>{guide.title}</h3>

            <a href={guide.imageSrc} target="_blank" class="image-link">
            <img
                src={guide.webImageSrc || guide.imageSrc}
                alt={guide.imageAlt}
                class="infographic"
                loading="lazy"
            />
            </a>

          <p class="caption">
            <a href={guide.imageSrc} target="_blank" class="caption-link">
            CLICK FULL-SIZE INFOGRAPHIC
            </a>
          </p>

          {getGuideReplayRows(guide, seasonReplays).length > 0 && (
            <>
              <h4 class="replay-title">YouTube Replays</h4>

              <div class="notes-box">              
              <table class="video-guide-table">
                <thead>
                  <tr>
                    <th>Tier</th>
                    <th>Boss</th>
                    <th>Team</th>
                    <th>Damage</th>
                    <th>Creator</th>
                  </tr>
                </thead>

                <tbody>
                  {getGuideReplayRows(guide, seasonReplays).map((row) => (
                    <tr>
                      <td>
                        <a href={row.URL} target="_blank" rel="noopener noreferrer">
                          {row.TIER}
                        </a>
                      </td>
                      <td>
                        <a href={row.URL} target="_blank" rel="noopener noreferrer">
                          {row.BOSS}
                        </a>
                      </td>
                      <td>
                        <a href={row.URL} target="_blank" rel="noopener noreferrer">
                          {row.TEAM}
                        </a>
                      </td>
                      <td>
                        <a href={row.URL} target="_blank" rel="noopener noreferrer">
                          {row.DAMAGE}
                        </a>
                      </td>
                      <td>
                        <a href={row.URL} target="_blank" rel="noopener noreferrer">
                          {row.CREATOR}
                        </a>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>
          )}
        </article>
      ))}
    </div>
  </section>

<section class="content-section">
  <h2>Related Guides</h2>

  <div class="card-grid">
    {sortedRelatedGuides.map((graphic) => (
        <a
          class={`card related-guide-card ${
            graphic.href === "/guild-raid/boss-meta" ||
            graphic.href === "/guild-raid/archive"
              ? "forced-related-card"
              : ""
          }`}
          href={graphic.href}
        >
        <div class="card-image-wrap">
          <img
            src={graphic.thumbnail}
            alt={`${graphic.title} preview`}
            class="card-image"
            loading="lazy"
          />
        </div>

        <h3>{graphic.title}</h3>
        <p>{graphic.description}</p>
      </a>
    ))}
  </div>
</section>

<script>
  const cards = Array.from(document.querySelectorAll(".related-guide-card"));

  const forcedCards = cards.filter((card) =>
    card.classList.contains("forced-related-card")
  );

  const randomCards = cards.filter(
    (card) => !card.classList.contains("forced-related-card")
  );

  randomCards
    .sort(() => Math.random() - 0.5)
    .forEach((card, index) => {
      card.style.display = index < 3 ? "block" : "none";
    });

  forcedCards.forEach((card) => {
    card.style.display = "block";
  });
</script>

</main>

<Footer />

<style>
  :global(body) {
    background-color: #121212;
    color: #f5f5f5;
    font-family: 'Lexend', sans-serif;
    margin: 0;
    overflow-x: hidden;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 6vw, 3rem);
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto;
    color: #cccccc;
  }

  .infographic-section {
    background: #1e1e1e;
    border: 1px solid #333;
    border-radius: 12px;
    padding: 1.5rem;
  }

  .infographic-section h2,
  .guide-card h3 {
    color: #d4af37;
    margin-top: 0;
  }

  .guide-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .guide-card {
    border-top: 1px solid #333;
    padding-top: 1.5rem;
  }

  .image-link {
    display: block;
  }

  .infographic {
    max-width: 700px;
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    margin: 0 auto;
  }

    .caption-link {
    display: block;
    text-align: center;
    color: #d4af37;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
    margin-top: 1rem;
    }

    .caption-link:hover {
    text-decoration: underline;
    }

  .notes-box {
    max-width: 700px;
    margin: 1rem auto 0;
    padding: 1rem;
    background: #252525;
    border: 1px solid #333;
    border-radius: 8px;
  }

  .video-guide-table {
    width: 100%;
    border-collapse: collapse;
  }

  .video-guide-table th,
  .video-guide-table td {
    padding: 0.75rem;
    border-bottom: 1px solid #333;
    vertical-align: top;
    text-align: left;
  }

  .video-guide-table th {
    color: #d4af37;
  }

  .video-guide-table td:first-child,
  .video-guide-table td:nth-child(2),
  .video-guide-table td:nth-child(4) {
    white-space: nowrap;
  }

  .video-guide-table a {
    color: #f5f5f5;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .video-guide-table a:hover {
    color: #d4af37;
    text-decoration: underline;
  }

  @media (max-width: 700px) {
    main {
      padding: 1.25rem;
    }

    .hero {
      margin-bottom: 2rem;
    }

    .infographic-section {
      padding: 1.25rem;
    }
  }

  .content-section {
  background: #1e1e1e;
  border: 1px solid #333;
  border-radius: 12px;
  padding: 1.5rem;
  margin-top: 4rem;
}

.content-section h2 {
  color: #d4af37;
  margin-top: 0;
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid #333;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 320px));
  gap: 1.5rem;
  justify-content: start;
}

.card {
  background: #121212;
  border: 1px solid #333;
  border-radius: 12px;
  padding: 1.5rem;
  text-decoration: none;
  color: inherit;
  transition: border-color 0.2s ease, transform 0.2s ease;
}

.card:hover,
.card:focus-visible {
  border-color: #d4af37;
  transform: translateY(-3px);
  outline: none;
}

.card-image-wrap {
  width: 100%;
  height: 120px;
  overflow: hidden;
  border-radius: 8px;
  margin-bottom: 1rem;
  background: #121212;
  border: 1px solid #333;
}

.card-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: top;
  display: block;
}

.card h3 {
  margin: 0 0 0.5rem;
  color: #d4af37;
  font-size: 1.1rem;
  line-height: 1.3;
}

.card p {
  color: #cccccc;
  line-height: 1.5;
  margin-bottom: 0;
}

.boss-meta-cta {
  max-width: 900px;
  margin: 0 auto 3rem;
  padding: 1.5rem;
  text-align: center;
  border: 1px solid rgba(212, 175, 55, 0.3);
  border-radius: 12px;
  background: rgba(212, 175, 55, 0.05);
}

.boss-meta-cta h2 {
  color: #d4af37;
  margin-top: 0;
  margin-bottom: 0.75rem;
}

.boss-meta-cta p {
  margin: 0 auto 1rem;
  max-width: 700px;
  line-height: 1.6;
  color: #cccccc;
}

.boss-meta-button {
  display: inline-block;
  padding: 0.75rem 1.5rem;
  background: #d4af37;
  color: #111;
  text-decoration: none;
  font-weight: 700;
  border-radius: 8px;
  transition: opacity 0.2s ease;
}

.boss-meta-button:hover,
.boss-meta-button:focus-visible {
  opacity: 0.85;
}

.replay-title {
  max-width: 700px;
  margin: 1.5rem auto 0.5rem;
  color: #d4af37;
  font-size: 1.1rem;
  font-weight: 700;
}

</style>