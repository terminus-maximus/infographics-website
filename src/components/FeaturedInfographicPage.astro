---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import { marked } from "marked";
import { graphics } from "../data/graphics";

const {
  title,
  description,
  imageSrc,
  imageAlt,
  lastUpdated,
  basicsTitle,
  basicsContent,
  resources = []
} = Astro.props;

const basicsHtml = basicsContent ? marked.parse(basicsContent) : "";

const relatedGuides = graphics.filter((g) => g.href !== Astro.url.pathname);
---

<Header />

<main>
  <section class="hero">
    <h1>{title}</h1>
    <p>{description}</p>

    {lastUpdated && (
      <p class="last-updated">Last Updated: {lastUpdated}</p>
    )}
  </section>

  <section class="infographic-section">
    <h2>Featured Infographic</h2>

    <a href={imageSrc} target="_blank" class="image-link">
      <img
        src={imageSrc}
        alt={imageAlt}
        class="infographic"
      />
    </a>

    <p class="caption">
      Click the infographic to view and download the full-resolution image.
    </p>
  </section>

  {basicsContent && (
    <section class="content-section">
      <h2>{basicsTitle || `${title} Basics`}</h2>
      <div class="markdown-content" set:html={basicsHtml} />
    </section>
  )}

  {resources.length > 0 && (
    <section class="content-section">
      <h2>Other Resources</h2>

      <ul class="resource-list">
        {resources.map((resource) => (
          <li>
            <a href={resource.url} target="_blank" rel="noopener noreferrer">
              {resource.title}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="content-section">
    <h2>Related Guides</h2>

    <div class="card-grid">
      {relatedGuides.map((graphic) => (
        <a class="card related-guide-card" href={graphic.href}>
          <div class="card-image-wrap">
            <img
              src={graphic.thumbnail}
              alt={`${graphic.title} preview`}
              class="card-image"
              loading="lazy"
            />
          </div>

          <h3>{graphic.title}</h3>
          <p>{graphic.description}</p>
        </a>
      ))}
    </div>
  </section>
</main>

<script>
  const cards = Array.from(document.querySelectorAll(".related-guide-card"));

  cards
    .sort(() => Math.random() - 0.5)
    .forEach((card, index) => {
      card.style.display = index < 3 ? "block" : "none";
    });
</script>

<Footer />

<style>
  :global(body) {
    background-color: #121212;
    color: #f5f5f5;
    font-family: 'Lexend', sans-serif;
    margin: 0;
    overflow-x: hidden;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 6vw, 3rem);
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto;
    color: #cccccc;
  }

  .last-updated {
    margin-top: 1rem !important;
    font-size: 0.95rem !important;
    color: #d4af37 !important;
  }

  section {
    margin-bottom: 4rem;
  }

  section h2 {
    color: #d4af37;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #333;
  }

  .infographic-section,
  .content-section {
    background: #1e1e1e;
    border: 1px solid #333;
    border-radius: 12px;
    padding: 1.5rem;
  }

  .image-link {
    display: block;
  }

  .infographic {
    max-width: 700px;
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    margin: 0 auto;
  }

  .caption {
    color: #cccccc;
    margin-bottom: 0;
  }

  .markdown-content {
    color: #cccccc;
    line-height: 1.7;
  }

  .markdown-content :global(a),
  .resource-list a {
    color: #d4af37;
  }

  .resource-list {
    margin-bottom: 0;
    color: #cccccc;
    line-height: 1.7;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 320px));
    gap: 1.5rem;
    justify-content: start;
  }

  .card {
    background: #121212;
    border: 1px solid #333;
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .card:hover,
  .card:focus-visible {
    border-color: #d4af37;
    transform: translateY(-3px);
    outline: none;
  }

  .card-image-wrap {
    width: 100%;
    height: 120px;
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 1rem;
    background: #121212;
    border: 1px solid #333;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: top;
    display: block;
  }

  .card h3 {
    margin: 0 0 0.5rem;
    color: #d4af37;
    font-size: 1.1rem;
    line-height: 1.3;
  }

  .card p {
    color: #cccccc;
    line-height: 1.5;
    margin-bottom: 0;
  }

  @media (max-width: 700px) {
    main {
      padding: 1.25rem;
    }

    .hero {
      margin-bottom: 2rem;
    }

    section {
      margin-bottom: 3rem;
    }

    .infographic-section,
    .content-section {
      padding: 1rem;
    }

    .card-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .card {
      padding: 1rem;
    }

    .card-image-wrap {
      height: 110px;
    }
  }
</style>