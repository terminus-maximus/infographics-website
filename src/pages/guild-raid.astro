---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const guides = [
  {
    title: "Mythic Bosses",
    imageSrc: "/images/guild-raid-s101-mythic.png",
    imageAlt: "Guild Raid Season 101 Mythic Bosses Infographic"
  },
  {
    title: "Legendary Bosses",
    imageSrc: "/images/guild-raid-s101-legendary.png",
    imageAlt: "Guild Raid Season 101 Legendary Bosses Infographic"
  },
  {
    title: "Epic Bosses",
    imageSrc: "/images/guild-raid-s101-epic.png",
    imageAlt: "Guild Raid Season 101 Epic Bosses Infographic"
  },
  {
    title: "Coming Soon",
    imageSrc: "/images/guild-raid-s101-coming-soon.png",
    imageAlt: "Guild Raid Season 101 Coming Soon Infographic"
  }
];
---

<Header />

<main>
  <section class="hero">
    <h1>Guild Raid Guide</h1>
    <p>
      Boss lineups, maps, and recommended teams for the current Guild Raid season.
    </p>
  </section>

  <section class="infographic-section">
    <h2>Season 101 Infographics</h2>

    <div class="guide-grid">
      {guides.map((guide) => (
        <article class="guide-card">
          <h3>{guide.title}</h3>

          <a href={guide.imageSrc} target="_blank" class="image-link">
            <img
              src={guide.imageSrc}
              alt={guide.imageAlt}
              class="infographic"
            />
          </a>

          <p class="caption">
            Click the infographic to view and download the full-resolution image.
          </p>
        </article>
      ))}
    </div>
  </section>
</main>

<Footer />

<style>
  :global(body) {
    background-color: #121212;
    color: #f5f5f5;
    font-family: 'Lexend', sans-serif;
    margin: 0;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 1.2rem;
    max-width: 700px;
    margin: 0 auto;
    color: #cccccc;
  }

  .infographic-section {
    background: #1e1e1e;
    border: 1px solid #333;
    border-radius: 10px;
    padding: 1.5rem;
  }

  .infographic-section h2 {
    color: #d4af37;
    margin-top: 0;
  }

  .guide-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .guide-card {
    border-top: 1px solid #333;
    padding-top: 1.5rem;
  }

  .guide-card h3 {
    color: #d4af37;
    margin-top: 0;
  }

  .image-link {
    display: block;
  }

  .infographic {
    max-width: 700px;
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
    margin: 0 auto;
  }

  .caption {
    color: #cccccc;
    margin-bottom: 0;
  }
</style>