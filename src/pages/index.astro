---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { graphics } from "../data/graphics";

const startHere = graphics.filter((g) => g.category === "start");
const guildRaids = graphics.filter((g) => g.category === "raid");
const legendaryGuides = graphics.filter((g) => g.category === "legendary");
const gameEvents = graphics.filter((g) => g.category === "event");
const aboutPages = graphics.filter((g) => g.category === "about");
---

<head>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
</head>

<Header />

<main>
  <section>
    <h2>Start Here</h2>

    <div class="card-grid">
      {startHere.map((graphic) => (
        <a class="card" href={graphic.href}>
          <div class="card-image-wrap">
            <img
              src={graphic.thumbnail}
              alt={`${graphic.title} preview`}
              class="card-image"
              loading="lazy"
            />
          </div>

          <h3>{graphic.title}</h3>
          <p>{graphic.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section>
    <h2>Guild Raids</h2>

    <div class="card-grid">
      {guildRaids.map((graphic) => (
        <a class="card" href={graphic.href}>
          <div class="card-image-wrap">
            <img
              src={graphic.thumbnail}
              alt={`${graphic.title} preview`}
              class="card-image"
              loading="lazy"
            />
          </div>

          <h3>{graphic.title}</h3>
          <p>{graphic.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section>
    <h2>Legendary Guides</h2>

    <div class="card-grid">
      {legendaryGuides.map((graphic) => (
        <a class="card" href={graphic.href}>
          <div class="card-image-wrap">
            <img
              src={graphic.thumbnail}
              alt={`${graphic.title} preview`}
              class="card-image"
              loading="lazy"
            />
          </div>

          <h3>{graphic.title}</h3>
          <p>{graphic.description}</p>
        </a>
      ))}
    </div>
  </section>
  
  <section>
    <h2>Game Events</h2>

    <div class="card-grid">
      {gameEvents.map((graphic) => (
        <a class="card" href={graphic.href}>
          <div class="card-image-wrap">
            <img
              src={graphic.thumbnail}
              alt={`${graphic.title} preview`}
              class="card-image"
              loading="lazy"
            />
          </div>

          <h3>{graphic.title}</h3>
          <p>{graphic.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section>
    <h2>About</h2>

    <div class="card-grid">
      {aboutPages.map((graphic) => (
        <a class="card" href={graphic.href}>
          <div class="card-image-wrap">
            <img
              src={graphic.thumbnail}
              alt={`${graphic.title} preview`}
              class="card-image"
              loading="lazy"
            />
          </div>

          <h3>{graphic.title}</h3>
          <p>{graphic.description}</p>
        </a>
      ))}
    </div>
  </section>
</main>

<Footer />

<style>
  :global(body) {
    background-color: #121212;
    color: #f5f5f5;
    font-family: 'Lexend', sans-serif;
    margin: 0
    overflow-x: hidden;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero p {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto;
    color: #cccccc;
  }

  section {
    margin-bottom: 4rem;
  }

  section h2 {
    color: #d4af37;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #333;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 320px));
    gap: 1.5rem;
    justify-content: start;
  }

  .card {
    background: #1e1e1e;
    border: 1px solid #333;
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .card:hover,
  .card:focus-visible {
    border-color: #d4af37;
    transform: translateY(-3px);
    outline: none;
  }

  .card-image-wrap {
    width: 100%;
    height: 120px;
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 1rem;
    background: #121212;
    border: 1px solid #333;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: top;
    display: block;
  }

  .card h3 {
    margin: 0 0 0.5rem;
    color: #d4af37;
    font-size: 1.1rem;
    line-height: 1.3;
  }

  .card p {
    color: #cccccc;
    line-height: 1.5;
    margin-bottom: 0;
  }

  /* Mobile refinements */
  @media (max-width: 700px) {
    main {
      padding: 1.25rem;
    }

    .hero {
      margin-bottom: 2rem;
    }

    section {
      margin-bottom: 3rem;
    }

    .card-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .card {
      padding: 1rem;
    }

    .card-image-wrap {
      height: 110px;
    }
  }

</style>