---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { graphics } from "../data/graphics";
---

<Header />

<main>
  <section class="hero">
    <h1>Terminus Maximus</h1>
    <p>
      Tacticus infographics designed to help players progress faster and make
      smarter decisions.
    </p>
  </section>

  <section>
    <h2>Start Here</h2>

    <div class="card-grid">
      {graphics.map((graphic) => (
        <a class="card" href={graphic.href}>
          <div class="card-image-wrap">
            <img
              src={graphic.thumbnail}
              alt={`${graphic.title} preview`}
              class="card-image"
              loading="lazy"
            />
          </div>

          <h3>{graphic.title}</h3>
          <p>{graphic.description}</p>
        </a>
      ))}
    </div>
  </section>
</main>

<Footer />

<style>
  :global(body) {
    background-color: #121212;
    color: #f5f5f5;
    font-family: Arial, sans-serif;
    margin: 0;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 1.2rem;
    max-width: 700px;
    margin: 0 auto;
    color: #cccccc;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .card {
    background: #1e1e1e;
    border: 1px solid #333;
    border-radius: 10px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .card:hover {
    border-color: #d4af37;
    transform: translateY(-3px);
  }

  .card-image-wrap {
    width: 100%;
    height: 120px;
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 1rem;
    background: #121212;
    border: 1px solid #333;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: top;
    display: block;
  }

  .card h3 {
    margin-top: 0;
    color: #d4af37;
  }

  .card p {
    color: #cccccc;
  }
</style>