---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Header />

<main>
  <section class="hero">
    <h1>About Terminus Maximus</h1>
    <p>
      Tacticus infographics, strategy resources, and guides created to help players
      make smarter decisions and progress more efficiently.
    </p>
  </section>

  <section class="about-card">
    <img
      src="/images/terminus-maximus.png"
      alt="Terminus Maximus"
      class="profile-image"
    />

    <div class="about-text">
      <h2>Who Am I?</h2>

      <p>
        I'm Terminus Maximus, a long-time Tacticus player focused on creating
        infographics and strategy resources for the community.
      </p>

      <p>
        What started as Reddit posts evolved into a growing library of guides
        covering Campaign Events, Hero Release Events, Legendary Release Events,
        Guild Raids, Elite Campaigns, and beginner progression.
      </p>

      <p>
        The goal of this site is simple: provide clear, practical resources that
        help players spend less time searching and more time enjoying the game.
      </p>
    </div>
  </section>
</main>

<Footer />

<style>
  :global(body) {
    background-color: #121212;
    color: #f5f5f5;
    font-family: Arial, sans-serif;
    margin: 0;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 1.2rem;
    max-width: 700px;
    margin: 0 auto;
    color: #cccccc;
  }

  .about-card {
    background: #1e1e1e;
    border: 1px solid #333;
    border-radius: 10px;
    padding: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: center;
  }

  .profile-image {
    max-width: 300px;
    width: 100%;
    height: auto;
    border-radius: 10px;
  }

  .about-text {
    flex: 1;
    min-width: 300px;
  }

  .about-text h2 {
    color: #d4af37;
    margin-top: 0;
  }

  .about-text p {
    color: #cccccc;
    line-height: 1.6;
  }
</style>