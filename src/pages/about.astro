---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Header />

<main>
  <section class="content-section intro-section">
    <img
      src="/images/terminus-maximus.png"
      alt="Terminus Maximus"
      class="profile-image"
    />

    <div class="intro-text">
      <h2>About Me</h2>

      <p>
        I'm Terminus Maximus, a long-time Tacticus player focused on creating
        infographics and strategy resources for the community.
      </p>

      <p>
        What started as Reddit posts to help my guild has evolved into an official
        role as a Creator for Tacticus, working directly with Snowprint.
      </p>
    </div>
  </section>

  <section class="content-section">
    <h2>My Tacticus Experience</h2>

    <div class="entry">
      <h3>Guild Experience</h3>
      <ul>
        <li>Member of Bloody Rose: Main</li>
        <li>Guild Raid Rank: 1</li>
        <li>Guild War Rank: 1</li>
        <li>
          Guild Discord:
          <a href="https://discord.gg/bN269v34V" target="_blank" rel="noopener noreferrer">
            Join our Discord
          </a>
        </li>
      </ul>
    </div>

    <div class="divider"></div>

    <div class="entry">
      <h3>Roster Progress</h3>
      <ul>
        <li>Playing since October 2022</li>
        <li>
          View my roster:
          <a
            href="https://tacticusplanner.app/sharedRoster?username=TerminusMaximus&shareToken=4a64af58-a7ed-4a67-be6f-31a49b2f4c1b"
            target="_blank"
            rel="noopener noreferrer"
          >
            Public Roster
          </a>
        </li>
      </ul>
    </div>
  </section>

  <section class="content-section">
    <h2>My Gaming Experience</h2>

    <div class="entry">
      <h3>Warhammer 40,000: Tacticus</h3>
      <p class="dates">October 2022 to Present</p>
      <ul>
        <li>Strategy guide creator and infographic designer</li>
        <li>Focus areas: Guild Raids, Legendary Release Events, Campaign Events, and progression optimization</li>
        <li>Active contributor to the Reddit and Discord communities</li>
      </ul>
    </div>

    <div class="divider"></div>

    <div class="entry">
      <h3>Warhammer 40,000: Space Marine 2</h3>
      <p class="dates">December 2025 to Present</p>
      <ul>
        <li>Casual player</li>
        <li>Focus on Operations & Stratagems</li>
      </ul>
    </div>

    <div class="divider"></div>

    <div class="entry">
      <h3>Gaming Background</h3>
      <ul>
        <li>Lifelong gamer</li>
        <li>Legend of Zelda 1987</li>
        <li>Civilization II in 1996</li>
        <li>EverQuest player from 1999 to 2004</li>
        <li>EQ2 player from 2004 to 2017</li>
        <li>PokemonGo player from 2016 to 2022</li>
        <li> Tacticus 2022 to present</li>
        <li>Other interests include Dungeons & Dragons, music, and reading sci fi</li>
      </ul>
    </div>
  </section>

  <section class="content-section">
    <h2>Contact Me</h2>

    <p>
      Discord is my preferred platform for messages.
    </p>

    <p class="contact-list">
      Discord: terminus_maximus<br />
      Reddit:
      <a href="https://www.reddit.com/user/terminus_maximus/" target="_blank" rel="noopener noreferrer">
        u/terminus_maximus
      </a><br />
      YouTube:
      <a href="https://www.youtube.com/@TerminusMaximus" target="_blank" rel="noopener noreferrer">
        @TerminusMaximus
      </a>
    </p>
  </section>
</main>

<Footer />

<style>
  :global(body) {
    background-color: #121212;
    color: #f5f5f5;
    font-family: Arial, sans-serif;
    margin: 0;
  }

  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    color: #d4af37;
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: 1rem;
  }

  .hero p {
    color: #cccccc;
    font-size: 1.25rem;
    line-height: 1.7;
    max-width: 760px;
    margin: 0 auto;
  }

  .content-section {
    background: #1e1e1e;
    border: 1px solid #333;
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .intro-section {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .profile-image {
    width: 260px;
    max-width: 100%;
    border-radius: 12px;
  }

  .intro-text {
    flex: 1;
  }

  h2 {
    color: #d4af37;
    font-size: 2rem;
    margin-top: 0;
    margin-bottom: 1.25rem;
  }

  h3 {
    color: #f5f5f5;
    font-size: 1.45rem;
    margin-bottom: 0.35rem;
  }

  p,
  li {
    color: #cccccc;
    font-size: 1.1rem;
    line-height: 1.7;
  }

  ul {
    margin-top: 0.75rem;
    padding-left: 1.5rem;
  }

  .dates {
    color: #d4af37;
    font-size: 1rem;
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .divider {
    border-top: 1px solid #333;
    margin: 1.75rem 0;
  }

  a {
    color: #f5f5f5;
    text-decoration: underline;
    text-decoration-color: #d4af37;
    text-underline-offset: 4px;
  }

  a:hover {
    color: #d4af37;
  }

  .contact-list {
    line-height: 1.9;
  }

  @media (max-width: 700px) {
    main {
      padding: 1.25rem;
    }

    .intro-section {
      flex-direction: column;
      align-items: flex-start;
    }

    .content-section {
      padding: 1.5rem;
    }

    h2 {
      font-size: 1.7rem;
    }

    h3 {
      font-size: 1.3rem;
    }

    p,
    li {
      font-size: 1.05rem;
    }
  }
</style>