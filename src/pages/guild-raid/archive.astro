---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const seasons = [
  {
    title: "Season 102",
    href: "/guild-raid/s102",
    description: "Guild Raid Season 102 infographics and boss lineup archive.",
    thumbnail: "/images/guild-raid-s102-mythic.png"
  },
  {
    title: "Season 101",
    href: "/guild-raid/s101",
    description: "Guild Raid Season 101 infographics and boss lineup archive.",
    thumbnail: "/images/guild-raid-s101-mythic.png"
  }
];
---

<Header />

<main>
  <section class="hero">
    <h1>Guild Raid Archive</h1>
    <p>
      Browse previous Guild Raid seasons, boss lineups, maps, and infographic archives.
    </p>
  </section>

  <section class="archive-section">
    <h2>Available Seasons</h2>

    <div class="card-grid">
      {seasons.map((season) => (
        <a href={season.href} class="card">
          <div class="card-image-wrapper">
            <img
              src={season.thumbnail}
              alt={`${season.title} Guild Raid archive preview`}
              class="card-image"
            />
          </div>

          <div class="card-content">
            <h3>{season.title}</h3>
            <p>{season.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</main>

<Footer />

<style>
  :global(body) {
    background-color: #121212;
    color: #f5f5f5;
    font-family: 'Lexend', sans-serif;
    margin: 0;
    overflow-x: hidden;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .hero p {
    font-size: 1.2rem;
    max-width: 760px;
    margin: 0 auto;
    color: #cccccc;
  }

  .archive-section {
    background: #1e1e1e;
    border: 1px solid #333;
    border-radius: 10px;
    padding: 1.5rem;
  }

  .archive-section h2 {
    color: #d4af37;
    margin-top: 0;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 320px));
    gap: 1.5rem;
    justify-content: start;
  }

  .card {
    background: #252525;
    border: 1px solid #333;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .card:hover {
    border-color: #d4af37;
    transform: translateY(-3px);
  }

  .card-image-wrapper {
    height: 160px;
    background: #121212;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: top;
  }

  .card-content {
    padding: 1.25rem;
  }

  .card-content h3 {
    color: #d4af37;
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .card-content p {
    color: #cccccc;
    line-height: 1.5;
    margin-bottom: 0;
  }

  @media (max-width: 700px) {
    main {
      padding: 1.25rem;
    }

    .hero {
      margin-bottom: 2rem;
    }

    .hero h1 {
      font-size: 2.25rem;
    }

    .hero p {
      font-size: 1rem;
    }

    .archive-section {
      padding: 1.25rem;
    }

    .card-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>